or:#7d9db0}a:hover{color:#add2e6}figure{margin:0;padding:0}h2{text-transform:lowercase;font-weight:normal;font-size:4em;line-height:1;max-width:800px;margin:0.5em auto 0.5em}@media screen and (max-width: 800px){h2{font-size:3em}}h3{font-size:2em;line-height:1.1}html{background:#30434e;box-sizing:border-box;font-family:'Jost';line-height:1.4;color:#efefef}@media screen and (min-width: 900px){html{font-size:125%}}*,*::before,*::after{box-sizing:inherit}img,svg{max-width:100%;height:auto}main{display:grid;grid-template-columns:var(--grid-primary)}@media screen and (min-width: 75rem){main{grid-template-columns:var(--grid-desktop)}}main>*{grid-column:main-content}main p+p{margin-top:1.5em}svg{fill:#add2e6}table{grid-column:full-content;width:100%;margin:0 auto}td{padding:0 0.5em 0.5em 0;vertical-align:top}td:nth-child(1){width:30%}td:nth-child(2){width:20%}@media screen and (max-width: 800px){table tr{display:flex;flex-wrap:wrap;margin:0.5em 0;padding-bottom:0.5em;border-bottom:1px solid #476474}table tr:last-child{border-bottom:0}table td{padding:0 1em 0 0;width:33%}table td:nth-child(1){flex:100%;width:100%}table td:nth-child(2){width:33%}}ul{list-style-type:square}.banner{position:sticky;z-index:3;top:0;width:100%;display:flex;background:#476474;align-items:center;padding:0 3em}.banner a{color:#c1ddec}.banner .logo{max-height:50px}@media screen and (max-width: 800px){.banner{position:static;flex-direction:column;margin-bottom:1em;padding:0}.banner .logo{height:100px}.banner .blurb{order:3;width:100%;background:#577a8e;margin:0;padding:1em}}.banner__logo{margin:4px 1em}.box{width:100%;margin:4em auto}.box:first-of-type{margin-top:0}.box:last-of-type{margin-bottom:0}.box__header{display:flex;flex-wrap:wrap}.box__header h2{flex:100%;margin:0 0 0.5em}.box__header .date,.box__header .tags{flex:50%;margin:0;align-self:center}.box__main{max-width:800px;margin:0 auto;padding:0 4px}.box__footer{display:grid;grid-template-columns:[start] 1em [info] 1fr [credits] 1fr 1em [end];grid-gap:10px;border:2px solid #add2e6;margin-top:1.5em}@media screen and (max-width: 767px){.box__footer{grid-template-columns:[start] 1em [info credits] 1fr 1em [end]}}.box__footer__header{grid-column:start / end;text-align:center;font-weight:bold;background:#add2e6;color:#2a2a2a;padding:0.25em}.box__footer__info{grid-column:info}.box__footer__info p{display:flex}.box__footer__info strong{margin-right:1em}.box__footer__credits{grid-column:credits}.caption{font-size:0.75em}.date{font-weight:bold;font-size:0.75em;text-transform:uppercase}.form__label{font-size:0.75em}.form__text,.form__textarea{display:block;font-size:1rem;margin-bottom:1em}.name,.comment,.submit{grid-column:left}.email{grid-column:right}.form__textarea{width:70%;min-height:200px;padding:1px 9px;border-radius:5px}.gotcha{display:none}.gallery-info{text-align:center}.gallery-info .logo{width:500px;height:auto}.gallery-info__credits{display:flex;width:100%}.gallery-info__credits>*{flex:auto}.gallery{list-style:none;padding:0;display:flex;flex-wrap:wrap}.gallery__item{flex:0 1 50%;padding:2px}.gallery__item img{display:block}.gallery__item.major{flex:100%}.hero{display:grid;grid-template-rows:[start logo] 200px [nav news] 1fr [bottom] 200px [end];grid-template-columns:[start nav] 1fr [logo center] 1fr [news] 1fr [end];height:100vh;align-items:center;font-size:125%;background:#101519;overflow:hidden}.hero .logo{grid-row:logo;grid-column:logo;z-index:2;justify-self:center;width:264.903px;height:158.889px}.hero__image{grid-row:start / end;grid-column:start / end;width:100%;height:auto;object-fit:contain;align-self:end}@media screen and (min-width: 801px){.hero__image{max-height:calc(100vh - 50px)}}.hero__news{grid-row:news;grid-column:news;padding:0 10px;animation:slideFromRight 0.75s ease-in 2s forwards}.hero__nav{grid-row:nav;grid-column:nav;margin:0 !important;padding-left:40px;animation:slideFromLeft 0.75s ease-in 1s forwards}.hero__nav .nav__item{margin-bottom:1em;display:block}.hero__caption{position:relative;bottom:100%;margin:0 0 0 1em}@supports (animation-name: slideFromBottom){.hero__nav,.hero__news{opacity:0}}@media screen and (max-width: 800px){.hero{grid-template-rows:[start logo] auto [news] 1fr [nav] auto [end];grid-template-columns:[start logo nav news] 1fr [end]}.hero .logo{max-height:100px;align-self:start;margin-top:10px}.hero__image{height:100%;object-fit:cover}.hero__news{margin:0 auto;align-self:end;background:rgba(87,122,142,0.5);animation:slideFromBottom 0.75s ease-in 2s forwards}.hero__nav{align-self:end;padding-left:0;background:rgba(48,67,78,0.5);animation:slideFromBottom 0.75s ease-in 1s forwards;font-size:80%}.hero__nav .nav__item{display:inline-block;margin:0.25em}@supports (animation-name: slideFromBottom){.hero__news,.hero__nav{opacity:0}}}.logo{max-width:100%}.nav{margin-left:auto}.nav__list{list-style:none;padding-left:0}.nav__item{display:inline-block;margin:1em}.nav__item.active .nav__link{color:#f2f2f2}@media screen and (max-width: 800px){.nav{text-align:center;margin:0}.nav__item{margin:0.5em}}.portfolio{display:grid;grid-template:1fr / 1fr;margin:0 0 1em}.portfolio:hover .portfolio__image{filter:sepia(80%)}.portfolio:hover .portfolio__logo{transform:scale(1.1)}.portfolio__image{grid-column:1;grid-row:1;transition:.2s ease all;transform-origin:bottom left}.portfolio__logo{grid-column:1;grid-row:1;z-index:2;fill:#f2f2f2;transition:.4s ease all;max-width:50%;margin:20px;will-change:transform}.portfolio__logo.bottomleft{transform-origin:bottom left;align-self:end}.portfolio__logo.bottomright{align-self:end;justify-self:end;transform-origin:bottom right}.portfolio__logo.top{justify-self:center;transform-origin:top center}.portfolio__logo.topleft{transform-origin:top left}.portfolio__logo.topright{justify-self:end;transform-origin:top right}.resume table{width:100%;max-width:1000px;margin:0 auto}.resume td{padding:0 0.5em 0.5em 0;vertical-align:top}.resume td:nth-child(1){width:30%}.resume td:nth-child(2){width:20%}@media screen and (max-width: 800px){.resume tr{display:flex;flex-wrap:wrap;margin:0.5em 0;padding-bottom:0.5em;border-bottom:1px solid #476474}.resume tr:last-child{border-bottom:0}.resume td{padding:0 1em 0 0;width:33%}.resume td:nth-child(1){flex:100%;width:100%}.resume td:nth-child(2){width:33%}}.attachment{text-align:center}.big-quote{display:grid;grid-template-columns:var(--grid-template-columns);margin:0;padding:1em 0;text-align:center}.big-quote:nth-of-type(1n){background:#7d9db0}.big-quote:nth-of-type(2n){background:#577a8e}.big-quote blockquote{grid-column:full-content;font-size:2em}.big-quote blockquote::before{content:"\201C"}.big-quote blockquote::after{content:"\201D"}.big-quote figcaption{grid-column:main-content;margin:1em}.big-quote figcaption a{color:#000000cc}.heading{width:100%}.ui-list{list-style:none;padding-left:0}.blurb{font-size:0.75em;margin:1em}.full-bleed{grid-column:full-bleed}.small{font-size:75%}

